# Copy this file to .env and replace placeholders with real values.
# Never commit or publish .env.

SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

TICKETMASTER_API_KEY=your_ticketmaster_api_key
SEATGEEK_CLIENT_ID=your_seatgeek_client_id_optional
SEATGEEK_CLIENT_SECRET=your_seatgeek_client_secret_optional
SONGKICK_API_KEY=your_songkick_api_key_optional

GOOGLE_MAPS_API_KEY=your_google_maps_api_key_optional
YELP_API_KEY=your_yelp_api_key_optional
OPENWEATHER_API_KEY=your_openweather_api_key_optional

# Optional future price expansion. StubHub requires OAuth/application-only access.
STUBHUB_CLIENT_ID=optional_stubhub_client_id
STUBHUB_CLIENT_SECRET=optional_stubhub_client_secret
STUBHUB_ACCESS_TOKEN=optional_stubhub_access_token

OPENAI_API_KEY=your_openai_api_key_optional
OPENAI_MODEL=gpt-5.4-mini

FEEDBACK_DB_PATH=./data/feedback.sqlite
MODEL_PATH=./models/xgb_feedback_reranker.joblib
CHROMA_PATH=./data/chroma
